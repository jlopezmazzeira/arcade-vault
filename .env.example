# Copia este archivo a .env.local y rellena los valores.
# Las tres son variables de servidor: ninguna lleva prefijo NEXT_PUBLIC_.

# Clave de la API de Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# Remitente del correo de contacto.
# Con onboarding@resend.dev no hace falta verificar dominio, pero OJO:
# ese remitente SOLO entrega al correo de la cuenta de Resend. Con cualquier
# otro CONTACT_TO_EMAIL la API responde 200 y el correo nunca llega.
CONTACT_FROM_EMAIL=

# Destinatario: el equipo. Mientras el remitente sea onboarding@resend.dev,
# tiene que ser el correo con el que se creó la cuenta de Resend.
CONTACT_TO_EMAIL=
